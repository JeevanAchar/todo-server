{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "baseUrl": "./",
    "rootDir": "./src",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@app": ["./src/app"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
